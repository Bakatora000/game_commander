#!/usr/bin/env python3
"""Official Python entrypoint for Game Commander."""
from __future__ import annotations

import sys
from pathlib import Path


SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

from shared import cmd_main


def main() -> int:
    argv = ["--script-dir", str(SCRIPT_DIR), *sys.argv[1:]]
    return cmd_main.main(argv)


if __name__ == "__main__":
    sys.exit(main())
