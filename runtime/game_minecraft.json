{
  "id": "minecraft",
  "name": "Minecraft Java",
  "subtitle": "Serveur Java",
  "logo": "⛏",

  "server": {
    "binary":      "java",
    "service":     "minecraft-server",
    "install_dir": "/home/gameserver/minecraft_server",
    "max_players": 20
  },

  "web": {
    "url_prefix": "/minecraft",
    "flask_port": 5004,
    "admin_user": "admin"
  },

  "features": {
    "mods":    false,
    "config":  true,
    "console": true,
    "players": true
  },

  "permissions": [
    "start_server", "stop_server", "restart_server", "manage_config", "console", "manage_users"
  ],

  "theme": { "name": "minecraft" }
}
